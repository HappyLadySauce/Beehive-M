syntax = "v1"

info (
	title: "Beehive Gateway API"
	desc:  "WebSocket 网关入口与"
)

type (
	// HealthResp 健康检查 data 部分，顶层 code/msg 由统一响应格式提供
	HealthResp {}
)

@server (
	name:  gateway
	group: gateway
)
service gateway-api {
	@handler WsEntry
	get /ws

	@handler Health
	get /healthz returns (HealthResp)
}

